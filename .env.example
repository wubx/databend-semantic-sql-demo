# Copy this file to .env and fill in local values.
# Never put real credentials in this example file.

# Semantic execution gateway. Embedded uses Cube's compiler libraries in this process;
# cube-server keeps the existing HTTP integration with a Cube server.
SEMANTIC_GATEWAY=embedded
CUBE_REPOSITORY_PATH=/path/to/cube

# Cube Server mode only
CUBE_API_URL=http://localhost:4000/cubejs-api/v1
CUBE_API_SECRET=replace-with-a-local-secret

# Databend
DATABEND_DSN=databend://readonly_user:replace-with-password@localhost:8000/tpch_100?sslmode=disable

# Optional model generation and enrichment. Generated entities always remain drafts.
MODEL_GENERATOR_MAX_TABLES=20
MODELER_AI_TIMEOUT_MS=90000
MODELER_AI_MAX_TOKENS=1800
MODELER_LOG_PATH=logs/modeler-observability.jsonl
# Allows reviewed Draft YAML to replace/create semantic/entities/*.yaml.
# Existing files are copied to semantic/backups/ before replacement.
MODELER_PUBLISH_ENABLED=false

# AI provider (OpenAI-compatible API)
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=replace-with-your-api-key
AI_MODEL=gpt-4.1-mini
AI_REQUEST_TIMEOUT_MS=30000

# Proxy only for external AI/provider requests. Keep local services and Databend direct.
HTTPS_PROXY=http://127.0.0.1:7890
HTTP_PROXY=http://127.0.0.1:7890
NO_PROXY=127.0.0.1,localhost,192.168.1.100

# Demo server
PORT=4100
RESULT_ROW_LIMIT=500

# Append one JSON object per plan/execute request. Relative paths resolve from the process working directory.
QUERY_LOG_ENABLED=true
QUERY_LOG_PATH=logs/query-observability.jsonl

# AI integration is optional. The deterministic demo must work when disabled.
AI_ENABLED=false
