{
  "name": "databend-semantic-query-lab",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered, governed, and observable semantic query lab for Databend",
  "type": "commonjs",
  "scripts": {
    "build:semantic": "node src/build-manifest.js",
    "report:queries": "node src/report-queries.js",
    "validate:meta": "node src/validate-meta.js",
    "verify:runtime": "node src/verify-runtime.js",
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test test/*.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "databend-driver": "0.25.4",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
